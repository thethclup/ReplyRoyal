# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EVM_PRIVATE_KEY: Required for x402 payments on EVM networks (e.g. Base, Arbitrum).
# Must be a 0x-prefixed hex string.
EVM_PRIVATE_KEY=""

# SVM_PRIVATE_KEY: Required for x402 payments on Solana.
# Must be a base58-encoded string.
SVM_PRIVATE_KEY=""

# RESOURCE_SERVER_URL: The base URL of the paid API.
RESOURCE_SERVER_URL="http://localhost:4021"

# ENDPOINT_PATH: The specific endpoint path to call on the resource server.
ENDPOINT_PATH="/weather"
